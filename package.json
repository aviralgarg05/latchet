{
  "name": "latchet",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first task ledger for AI-assisted work.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -b && node scripts/run-site.mjs build",
    "clean": "find packages apps -type d \\( -name dist -o -name .tsbuildinfo \\) -prune -exec rm -rf {} + 2>/dev/null || true",
    "test": "npm run build && node --test packages/core/dist/test/*.test.js",
    "cli": "node packages/cli/dist/index.js",
    "mcp": "node packages/mcp/dist/index.js",
    "dev:site": "node scripts/run-site.mjs dev",
    "build:site": "node scripts/run-site.mjs build",
    "preview:site": "node scripts/run-site.mjs preview"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
