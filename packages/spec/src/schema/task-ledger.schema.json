{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://latchet.dev/schema/task-ledger.schema.json",
  "title": "Latchet Task Event",
  "type": "object",
  "required": [
    "id",
    "task_id",
    "timestamp",
    "actor",
    "source",
    "type",
    "payload"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "assistant",
            "tool",
            "system"
          ]
        },
        "name": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "manual",
            "cli",
            "mcp",
            "session",
            "conversation",
            "file",
            "command",
            "telemetry",
            "import"
          ]
        },
        "provider": {
          "type": "string"
        },
        "reference": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "type": {
      "type": "string",
      "enum": [
        "decision",
        "attempt",
        "failure",
        "env_quirk",
        "constraint",
        "artifact_ref",
        "open_question",
        "next_action",
        "status_change",
        "note",
        "evidence"
      ]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "value"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "event",
              "file",
              "command",
              "conversation",
              "url",
              "commit",
              "issue",
              "pull_request"
            ]
          },
          "value": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "verification": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "verified",
            "user_asserted",
            "model_inferred",
            "speculative",
            "rejected"
          ]
        },
        "note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "redaction": {
      "type": "object",
      "properties": {
        "contains_sensitive": {
          "type": "boolean"
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
