{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://latchet.dev/schema/task-ledger.schema.json",
  "title": "Latchet Task Event",
  "type": "object",
  "required": [
    "id",
    "task_id",
    "timestamp",
    "actor",
    "source",
    "type",
    "payload"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "assistant",
            "tool",
            "system"
          ]
        },
        "name": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "manual",
            "cli",
            "mcp",
            "session",
            "conversation",
            "file",
            "command",
            "telemetry",
            "import"
          ]
        },
        "provider": {
          "type": "string"
        },
        "reference": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "type": {
      "type": "string",
      "enum": [
        "decision",
        "attempt",
        "failure",
        "env_quirk",
        "constraint",
        "artifact_ref",
        "open_question",
        "next_action",
        "status_change",
        "note",
        "evidence"
      ]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "value"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "event",
              "file",
              "command",
              "conversation",
              "url",
              "commit",
              "issue",
              "pull_request"
            ]
          },
          "value": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "verification": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "verified",
            "user_asserted",
            "model_inferred",
            "speculative",
            "rejected"
          ]
        },
        "note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "redaction": {
      "type": "object",
      "properties": {
        "contains_sensitive": {
          "type": "boolean"
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "type": { "const": "decision" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["summary"],
            "properties": {
              "summary": { "type": "string", "minLength": 1 },
              "reason": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["proposed", "accepted", "rejected", "superseded"]
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "attempt" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["summary"],
            "properties": {
              "summary": { "type": "string", "minLength": 1 },
              "outcome": { "type": "string" },
              "result": {
                "type": "string",
                "enum": ["success", "failure", "partial"]
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "failure" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["summary"],
            "properties": {
              "summary": { "type": "string", "minLength": 1 },
              "error": { "type": "string" },
              "suspected_cause": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["open", "resolved"]
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "env_quirk" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["summary"],
            "properties": {
              "summary": { "type": "string", "minLength": 1 },
              "impact": { "type": "string" },
              "workaround": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "constraint" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["summary"],
            "properties": {
              "summary": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "artifact_ref" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "revision": { "type": "string" },
              "exists": { "type": "boolean" },
              "note": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "open_question" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["question"],
            "properties": {
              "question": { "type": "string", "minLength": 1 },
              "owner": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "next_action" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["summary"],
            "properties": {
              "summary": { "type": "string", "minLength": 1 },
              "priority": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              },
              "prerequisites": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "status_change" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["to"],
            "properties": {
              "to": {
                "type": "string",
                "enum": ["todo", "in_progress", "blocked", "done"]
              },
              "from": {
                "type": "string",
                "enum": ["todo", "in_progress", "blocked", "done"]
              },
              "reason": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "note" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["summary"],
            "properties": {
              "summary": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "evidence" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["summary"],
            "properties": {
              "summary": { "type": "string", "minLength": 1 },
              "kind": {
                "type": "string",
                "enum": ["log", "otel", "test", "command", "session"]
              },
              "details": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    }
  ]
}
